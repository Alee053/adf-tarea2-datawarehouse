{
	"name": "df_bronze_inventario",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "inventario_xlsx",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "derivedColumn6"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          codigo_producto as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          precio_venta as string,",
				"          costo_adquisicion as string,",
				"          stock_actual as string,",
				"          stock_minimo as string,",
				"          sucursal as string,",
				"          proveedor as string,",
				"          ultima_reposicion as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(codigo_producto = trim(codigo_producto),",
				"          nombre_producto = lower(trim(nombre_producto)),",
				"          categoria = lower(trim(categoria)),",
				"          sucursal = trim(sucursal),",
				"          proveedor = trim(proveedor)) ~> derivedColumn1",
				"derivedColumn1 derive(nombre_producto = initCap(regexReplace(nombre_producto, '\\\\s+', ' '))) ~> derivedColumn2",
				"derivedColumn2 derive(categoria = case(",
				"  in(['computadoras','laptops','pcs'], categoria), 'Computadoras',",
				"  in(['monitores','pantallas'], categoria), 'Monitores',",
				"  in(['perifericos','periféricos'], categoria), 'Perifericos',",
				"  in(['audio','sonido'], categoria), 'Audio',",
				"  in(['tablets','tabletas'], categoria), 'Tablets',",
				"  in(['impresoras','printers'], categoria), 'Impresoras',",
				"  in(['almacenamiento','storage'], categoria), 'Almacenamiento',",
				"  in(['accesorios','acc.'], categoria), 'Accesorios',",
				"  in(['redes','networking'], categoria), 'Redes',",
				"  in(['componentes','hardware'], categoria), 'Componentes',",
				"  categoria",
				"  )) ~> derivedColumn3",
				"derivedColumn3 derive(precio_venta = toFloat(regexReplace(toString(precio_venta), '[^0-9.]', '')),",
				"          activo = iif(in(['si','true','1','yes'],lower(trim(toString(activo)))),true(),false()),",
				"          sucursal = case(",
				"  in(['SCZ','Santa Cruz','Sta Cruz','santa cruz'], sucursal), 'Santa Cruz',",
				"  in(['LPZ','La Paz','LP','la paz'], sucursal), 'La Paz', sucursal)) ~> derivedColumn4",
				"derivedColumn4 derive(ultima_reposicion = coalesce(",
				"  toDate(ultima_reposicion, 'yyyy-MM-dd'),",
				"  toDate(ultima_reposicion, 'dd/MM/yyyy'),",
				"  toDate(ultima_reposicion, 'MM-dd-yyyy'),",
				"  toDate(ultima_reposicion, 'yyyy/MM/dd'),",
				"  toDate(ultima_reposicion, 'dd-MMM-yyyy'),",
				"  toDate(ultima_reposicion, 'MMMM dd, yyyy'),",
				"  toDate(ultima_reposicion, \"dd 'de' MMMM 'de' yyyy\")",
				")) ~> derivedColumn5",
				"derivedColumn5 derive(precio_venta = iifNull(precio_venta, 0.0, precio_venta),",
				"          costo_adquisicion = toFloat(iifNull(costo_adquisicion, \"0.0\", costo_adquisicion)),",
				"          stock_actual = toInteger(stock_actual)) ~> derivedColumn6",
				"derivedColumn6 select(mapColumn(",
				"          codigo_producto,",
				"          nombre_producto,",
				"          categoria,",
				"          precio_venta,",
				"          costo_adquisicion,",
				"          stock_actual,",
				"          sucursal,",
				"          proveedor,",
				"          ultima_reposicion,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}